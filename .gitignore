# ==========================================
# Freenet Core .gitignore
# ==========================================
# Subdirectory .gitignores handle their own build artifacts:
#   apps/.gitignore, tests/.gitignore,
#   network-monitor/.gitignore, modules/*/.gitignore

# ------------------------------------------
# Rust build artifacts
# ------------------------------------------
target/
target-docker/
debug/
**/*.rs.bk
*.pdb
rustc-ice*.txt

# Cargo config (developer-local symlink for shared target dir)
.cargo

# ------------------------------------------
# JavaScript / Node dependencies
# ------------------------------------------
**/node_modules/
**/bower_components/

# ------------------------------------------
# Subrepos and vendored dependencies
# Prevents nested repos and third-party code from upstream commits
# ------------------------------------------
**/.git/
**/.svn/
**/.hg/
**/.bzr/
**/vendor/
**/third_party/

# ------------------------------------------
# IDE and editors
# ------------------------------------------
.idea/
.vscode/
**/*.swp
**/*.swo
*~
\#*\#
.\#*
*Session.vim
.netrwhist
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ------------------------------------------
# OS generated files
# ------------------------------------------
.DS_Store
**/.DS_Store
**/._*
**/.Spotlight-V100
**/.Trashes
Thumbs.db
**/Thumbs.db
**/Desktop.ini
**/$RECYCLE.BIN/

# ------------------------------------------
# Environment and secrets
# ------------------------------------------
.env
.env.local
.env.*.local

# ------------------------------------------
# Developer-local config
# ------------------------------------------
config.toml
.rustc*
.tool-versions

# ------------------------------------------
# Local tools and scratch
# ------------------------------------------
.local-tools/
*.local/
*.local

# ------------------------------------------
# Release and deployment artifacts
# ------------------------------------------
release-artifacts/

# ------------------------------------------
# Git worktrees
# ------------------------------------------
.worktrees/
worktrees/

# ------------------------------------------
# Claude / AI assistant files
# ------------------------------------------
.claude/**
!.claude/settings.json
!.claude/rules/
!.claude/rules/**
.claude-plugin/
.claude-flow/
.swarm/
.aider*
aider.conf.yaml
aider_stdlib_map.md
claude_notes/
external_plugins/
plugins/

# ------------------------------------------
# Temporary and generated files
# ------------------------------------------
*.log
*.tmp
*.backup
*.bak
*.orig
*.rej
crates/core/tmp_work/
test-results/
logs/

# Project-specific generated docs/status
CI_STATUS.md
PR_*.md
GET_OPERATION_OPTIMIZATION_SUMMARY.md
INTEGRATION_TEST_FIX_STATUS.md
test_*.sh

# ------------------------------------------
# Profiling and debugging
# ------------------------------------------
perf.data*
*.prof
callgrind.out*
cachegrind.out*
massif.out*

# ------------------------------------------
# Container overrides (local only)
# ------------------------------------------
docker-compose.override.yml
docker-compose.local.yml

# ------------------------------------------
# Development tools
# ------------------------------------------
.vtcode/
.grepai/
